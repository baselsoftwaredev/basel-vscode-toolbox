{
  "name": "basel-vscode-toolbox",
  "displayName": "Basel vscode toolbox",
  "description": "Various tools for my vscode dev.",
  "publisher": "baselsoftwaredev",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onView:toolbox.changesView",
    "onView:toolbox.shelvesView",
    "onCommand:toolbox.shelveChanges",
    "onCommand:toolbox.unshelveChanges",
    "onCommand:toolbox.unshelveAndDelete",
    "onCommand:toolbox.deleteShelf",
    "onCommand:toolbox.renameShelf",
    "onCommand:toolbox.viewShelfPatch",
    "onCommand:toolbox.refreshShelves",
    "onCommand:extension.splitEditorRightLimited"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/baselsoftwaredev/basel-vscode-toolbox.git"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "toolbox-shelves",
          "title": "Shelves",
          "icon": "$(archive)"
        }
      ]
    },
    "views": {
      "toolbox-shelves": [
        {
          "id": "toolbox.changesView",
          "name": "Changes",
          "type": "webview"
        },
        {
          "id": "toolbox.shelvesView",
          "name": "Shelved Changes"
        }
      ]
    },
    "commands": [
      {
        "command": "extension.splitEditorRightLimited",
        "title": "Split Editor Right Limited"
      },
      {
        "command": "toolbox.shelveChanges",
        "title": "Shelve Changes",
        "icon": "$(archive)",
        "category": "Shelves"
      },
      {
        "command": "toolbox.unshelveChanges",
        "title": "Unshelve (Keep)",
        "icon": "$(arrow-down)",
        "category": "Shelves"
      },
      {
        "command": "toolbox.unshelveAndDelete",
        "title": "Unshelve and Delete",
        "icon": "$(arrow-down)",
        "category": "Shelves"
      },
      {
        "command": "toolbox.deleteShelf",
        "title": "Delete Shelf",
        "icon": "$(trash)",
        "category": "Shelves"
      },
      {
        "command": "toolbox.renameShelf",
        "title": "Rename Shelf",
        "icon": "$(pencil)",
        "category": "Shelves"
      },
      {
        "command": "toolbox.viewShelfPatch",
        "title": "View Patch",
        "icon": "$(diff)",
        "category": "Shelves"
      },
      {
        "command": "toolbox.refreshShelves",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Shelves"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "toolbox.shelveChanges",
          "when": "view == toolbox.shelvesView",
          "group": "navigation@1"
        },
        {
          "command": "toolbox.refreshShelves",
          "when": "view == toolbox.shelvesView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "toolbox.unshelveChanges",
          "when": "view == toolbox.shelvesView && viewItem == shelf",
          "group": "1_shelve@1"
        },
        {
          "command": "toolbox.unshelveAndDelete",
          "when": "view == toolbox.shelvesView && viewItem == shelf",
          "group": "1_shelve@2"
        },
        {
          "command": "toolbox.viewShelfPatch",
          "when": "view == toolbox.shelvesView && viewItem == shelf",
          "group": "2_view@1"
        },
        {
          "command": "toolbox.renameShelf",
          "when": "view == toolbox.shelvesView && viewItem == shelf",
          "group": "3_manage@1"
        },
        {
          "command": "toolbox.deleteShelf",
          "when": "view == toolbox.shelvesView && viewItem == shelf",
          "group": "3_manage@2"
        }
      ],
      "commandPalette": [
        {
          "command": "toolbox.shelveChanges",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "toolbox.unshelveChanges",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "toolbox.unshelveAndDelete",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "toolbox.deleteShelf",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "toolbox.renameShelf",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "toolbox.viewShelfPatch",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "toolbox.refreshShelves"
        }
      ]
    },
    "keybindings": [
      {
        "command": "extension.splitEditorRightLimited",
        "key": "cmd+r",
        "when": "editorTextFocus"
      },
      {
        "command": "extension.splitEditorRightLimited",
        "key": "cmd+t",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts --fix",
    "test": "npm run compile && node ./out/test/runTest.js",
    "build": "npm run lint && npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.2.3",
    "@types/node": "14.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "glob": "^7.1.7",
    "mocha": "^8.4.0",
    "typescript": "^4.3.5",
    "vscode-test": "^1.6.1"
  }
}
