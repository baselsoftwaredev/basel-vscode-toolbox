{
    "name": "your-extension-name",
    "displayName": "Your Extension Name",
    "description": "Your extension description",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.95.0"
    },
    "activationEvents": [
        "onCommand:extension.splitEditorRightLimited"
    ],
    "main": "./out/extension.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/your-username/your-repository.git"
    },
    "contributes": {
        "commands": [
            {
                "command": "extension.splitEditorRightLimited",
                "title": "Split Editor Right Limited"
            }
        ],
        "keybindings": [
            {
                "command": "extension.splitEditorRightLimited",
                "key": "cmd+t",
                "when": "editorTextFocus"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^7.1.3",
        "@types/mocha": "^8.2.2",
        "@types/node": "14.x",
        "@types/vscode": "^1.95.0",
        "@typescript-eslint/eslint-plugin": "^4.28.2",
        "@typescript-eslint/parser": "^4.28.2",
        "eslint": "^7.29.0",
        "glob": "^7.1.7",
        "mocha": "^8.4.0",
        "typescript": "^4.3.5",
        "vscode-test": "^1.5.2"
    }
}
