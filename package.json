{
    "name": "basel-vscode-toolbox",
    "displayName": "Basel vscode toolbox",
    "description": "Various tools for my vscode dev.",
    "publisher": "baselsoftwaredev",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.95.0"
    },
    "activationEvents": [
        "onCommand:extension.splitEditorRightLimited"
    ],
    "main": "./out/extension.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/baselsoftwaredev/basel-vscode-toolbox.git"
    },
    "contributes": {
        "commands": [
            {
                "command": "extension.splitEditorRightLimited",
                "title": "Split Editor Right Limited"
            }
        ],
        "keybindings": [
            {
                "command": "extension.splitEditorRightLimited",
                "key": "cmd+t",
                "when": "editorTextFocus"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts --fix",
        "test": "npm run compile && node ./out/test/runTest.js",
        "build": "npm run lint && npm run compile && vsce package"
    },
    "devDependencies": {
        "@types/glob": "^7.1.3",
        "@types/mocha": "^8.2.3",
        "@types/node": "14.x",
        "@types/vscode": "^1.95.0",
        "@typescript-eslint/eslint-plugin": "^8.16.0",
        "@typescript-eslint/parser": "^8.16.0",
        "eslint": "^8.57.1",
        "eslint-config-standard": "^17.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-n": "^16.6.2",
        "eslint-plugin-promise": "^6.6.0",
        "glob": "^7.1.7",
        "mocha": "^8.4.0",
        "typescript": "^4.3.5",
        "vscode-test": "^1.6.1"
    }
}
